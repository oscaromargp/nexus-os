{
  "name": "nexus-os-app",
  "private": true,
  "version": "2.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "handoff": "bash scripts/handoff.sh",
    "context:save": "echo 'Snapshot guardado en .opencode/context/$(date +%s).json' && mkdir -p .opencode/context && cat > .opencode/context/$(date +%s).json <<< '{\"timestamp\":\"$(date -Iseconds)\",\"branch\":\"$(git branch --show-current)\",\"lastCommit\":\"$(git log --oneline -1)\",\"files\":$(git status --porcelain | jq -R . | jq -s .)}'",
    "context:load": "ls -t .opencode/context/*.json 2>/dev/null | head -1 | xargs -I {} cat {} | jq ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "chart.js": "^4.5.1",
    "chrono-node": "^2.9.1",
    "daisyui": "^5.5.20",
    "fuse.js": "^7.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "leaflet": "^1.9.4",
    "lucide": "^1.16.0",
    "qrcode": "^1.5.4",
    "sortablejs": "^1.15.7",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "playwright": "^1.60.0",
    "postcss": "^8.5.3",
    "puppeteer-core": "^24.42.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.2",
    "vitest": "^4.1.5"
  }
}
