# Copia este archivo como .env y rellena tus valores de Supabase
# Supabase > Settings > API

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ── n8n Webhook (api/n8n.js) ──────────────────────────────────────────────────
# Token secreto para autenticar peticiones de n8n.
# Genera uno con: openssl rand -hex 32
NEXUS_WEBHOOK_SECRET=

# Service Role Key de Supabase (NO la anon key).
# Supabase > Settings > API > service_role key
# Necesaria para que el webhook inserte nodos bypassando RLS.
NEXUS_SUPABASE_SERVICE_KEY=
